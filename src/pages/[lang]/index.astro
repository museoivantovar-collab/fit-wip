---
import { guardLocale, type Locale } from "../../lib/i18n";
import WipPage from "../../components/wip/WipPage.astro";

export function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "fr" } }];
}

const { lang } = Astro.params as { lang: string };
const invalid = guardLocale(lang);
if (invalid) return invalid;
---

<WipPage lang={lang as Locale} />
